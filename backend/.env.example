# ─── Application ──────────────────────────────────────────────────────────────
APP_NAME="AI Council"
APP_ENV=development
DEBUG=true
SECRET_KEY=your-super-secret-key-change-in-production
API_V1_PREFIX=/api/v1

# ─── Database (SQLite — no external DB required) ──────────────────────────────
DATABASE_URL=sqlite+aiosqlite:///./ai_council.db

# ─── Redis (optional — falls back to asyncio if not running) ──────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_URL=redis://localhost:6379/0

# ─── Celery (optional — falls back to asyncio if Redis is absent) ─────────────
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# ─── Groq API (required) ──────────────────────────────────────────────────────
# Get your key at: https://console.groq.com
GROQ_API_KEY=gsk_your_groq_api_key_here
GROQ_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
GROQ_MAX_TOKENS=4096
GROQ_TEMPERATURE=0.7

# ─── JWT Auth ─────────────────────────────────────────────────────────────────
JWT_SECRET_KEY=your-jwt-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60

# ─── CORS ─────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ─── Bluesky / AT Protocol (required for publishing) ─────────────────────────
# Handle:   your username, e.g. yourname.bsky.social
# Password: create an App Password at https://bsky.app/settings/app-passwords
BLUESKY_HANDLE=yourhandle.bsky.social
BLUESKY_PASSWORD=your-bluesky-app-password

# ─── Cloudflare Workers AI (required for image generation) ───────────────────
# Free tier: 10,000 neurons/day (~500-1000 images). No credit card needed.
# Account ID and API Token: https://dash.cloudflare.com/profile/api-tokens
CF_ACCOUNT_ID=your-cloudflare-account-id
CF_API_TOKEN=your-cloudflare-api-token

# ─── Hugging Face (not actively used — kept for reference) ───────────────────
# HF_TOKEN=hf_your_token_here
